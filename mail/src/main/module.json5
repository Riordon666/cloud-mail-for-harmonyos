{
  "module": {
    "name": "mail",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "MailAbility",
    "deviceTypes": [
      "phone",
      "tablet"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET"
      },
      {
        "name": "ohos.permission.DETECT_GESTURE"
      }
    ],"abilities": [
      {
        "name": "MailAbility",
        "srcEntry": "./ets/mailability/MailAbility.ets",
        "description": "$string:MailAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:MailAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "MailBackupAbility",
        "srcEntry": "./ets/mailbackupability/MailBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ],
      }
    ]
  }
}